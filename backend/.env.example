DATABASE_URL="postgresql://postgres:postgres@localhost:5432/btp_life?schema=public"
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
PORT=4000
CORS_ORIGIN="http://localhost:3000"
# Notifications push — générer une paire avec `node -e "console.log(require('web-push').generateVAPIDKeys())"`
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@btp-life.app"
# Secret partagé avec le cron Vercel (header x-cron-secret) — voir vercel.json
CRON_SECRET=""
# Reste à "false" tant que l'envoi réel aux joueurs inactifs n'est pas confirmé
CRON_ENVOI_ACTIF="false"
